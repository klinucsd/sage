+def _generate_workflow(output_dir_str):
+    """Generate workflow_diagram.workflow.html from notebook + cell registry.
+
+    Returns the Path to the generated file, or None on failure.
+    """
+    output_dir = Path(output_dir_str)
+    registry_path = output_dir / '.sage_cells.json'
+
+    cell_registry = {}
+    if registry_path.exists():
+        try:
+            cell_registry = json.loads(registry_path.read_text())
+        except Exception:
+            pass
+
+    notebook_path = _wf_find_notebook(output_dir)
+    notebook_cells = _wf_read_notebook_cells(notebook_path)
+
+    # Keep cells that either produced tracked files OR made tool calls.
+    # A cell with only `python -c "..."` or only tool calls still did real work
+    # and deserves to be in the diagram.
+    cells_with_files = []
+    for cell in notebook_cells:
+        files = cell_registry.get(cell.get('id', ''), [])
+        has_tool_activity = bool(_re_mod.search(
+            r'<b>(execute|write_file|http_request|fetch_url|read_file)</b>',
+            cell.get('outputs_html', ''),
+        ))
+        if files or has_tool_activity:
+            cells_with_files.append((cell, files))
+
+    # Fallback: use registry order if no notebook
+    if not cells_with_files and cell_registry:
+        for i, (rcid, files) in enumerate(cell_registry.items()):
+            cells_with_files.append((
+                {'id': rcid, 'prompt': f'Cell #{i+1}', 'outputs_html': ''},
+                files,
+            ))
+
+    if not cells_with_files:
+        return None
+
+    # Build per-cell data
+    cell_data = []
+    for i, (cell, files) in enumerate(cells_with_files):
+        skills, commands = _wf_parse_outputs(cell['outputs_html'])
+        runners = _wf_detect_runners(commands)
+        inline_code = _wf_extract_inline_code(cell['outputs_html'])
+        info = _wf_analyze_scripts(files, inline_code_blocks=inline_code)
+
+        # If no sub-steps from scripts or inline code, fall back to tool calls
+        sub_steps = info['sub_steps']
+        if not sub_steps:
+            sub_steps = _wf_tool_call_substeps(cell['outputs_html'])
+
+        output_files = sorted({Path(f).name for f in files if not str(f).endswith('.py')})
+
+        cell_data.append({
+            'index': i + 1,
+            'prompt': cell['prompt'],
+            'skills': skills,
+            'runners': runners,
+            'imports': info['imports'],
+            'sub_steps': sub_steps,
+            'docstring': info['docstring'],
+            'output_files': output_files,
+        })
+
+    # Build cytoscape elements
+    elements = []
+    for cell in cell_data:
+        ci = cell['index']
+        cid = f"cell_{ci}"
+        prompt_display = _wf_wrap_text(cell['prompt'], 36, 3)
+        title = f"Cell {ci}: {prompt_display}"
+        meta = []
+        if cell['skills']:
+            meta.append(f"skill: {', '.join(cell['skills'])}")
+        if cell['runners']:
+            meta.append(f"runner: {', '.join(cell['runners'])}")
+        if cell['imports']:
+            meta.append(f"uses: {', '.join(cell['imports'][:4])}")
+        label = title
+        if meta:
+            label += '\n\n' + '\n'.join(meta)
+        elements.append({'data': {'id': cid, 'label': label, 'type': 'cell_container'}})
+
+        sub_steps = cell['sub_steps'][:]
+        if not sub_steps and cell['docstring']:
+            sub_steps = [cell['docstring'][:60]]
+        if not sub_steps:
+            sub_steps = ['Execute script'] if cell['output_files'] else ['(no files)']
+
+        prev = None
+        for j, step in enumerate(sub_steps):
+            sid = f"{cid}_s{j+1}"
+            elements.append({'data': {'id': sid, 'label': step, 'parent': cid, 'type': 'substep'}})
+            if prev:
+                elements.append({'data': {'source': prev, 'target': sid}})
+            prev = sid
+
+        for k, fname in enumerate(cell['output_files'][:6]):
+            fid = f"{cid}_f{k+1}"
+            elements.append({'data': {'id': fid, 'label': fname, 'parent': cid, 'type': 'output_file'}})
+            if prev:
+                elements.append({'data': {'source': prev, 'target': fid}})
+
+    for i in range(len(cell_data) - 1):
+        elements.append({
+            'data': {
+                'source': f"cell_{cell_data[i]['index']}",
+                'target': f"cell_{cell_data[i+1]['index']}",
+                'type': 'cell_flow',
+            }
+        })
+
+    html = _WF_HTML_TEMPLATE.replace('__ELEMENTS__', json.dumps(elements, indent=2))
+    out_path = output_dir / 'workflow_diagram.workflow.html'
+    out_path.write_text(html, encoding='utf-8')
+    return out_path
 
 
