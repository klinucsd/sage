+# ---------------------------------------------------------------------------
+# Workflow diagram generator (used by %workflow magic)
+# ---------------------------------------------------------------------------
+# Reads the notebook .ipynb, .sage_cells.json, and per-cell Python scripts
+# to produce workflow_diagram.workflow.html (cytoscape.js compound nodes).
+
+import ast as _ast
+import tokenize as _tokenize
+from io import BytesIO as _BytesIO
+
+_COMMON_UTIL_MODULES = {
+    'os', 'sys', 'json', 're', 'io', 'time', 'datetime', 'math', 'random',
+    'pathlib', 'typing', 'collections', 'functools', 'itertools', 'warnings',
+    'copy', 'ast', 'tokenize', 'subprocess', 'shutil', 'glob', 'tempfile',
+    'numpy', 'pandas', 'matplotlib', 'seaborn',
+}
+
+import re as _re_mod
+_WF_SKILL_RE = _re_mod.compile(
+    r'<b>read_file</b>[^<]*?Reading:\s*<code>([^<]*skills/([^/<]+)/SKILL\.md)</code>',
+    _re_mod.IGNORECASE,
+)
+_WF_EXEC_RE = _re_mod.compile(
+    r'<b>execute</b>[^<]*?Executing:\s*<code>([^<]+)</code>',
+    _re_mod.IGNORECASE,
+)
+
+
+def _wf_find_notebook(output_dir):
+    """Derive notebook path: /path/_{stem}_sage_/ → /path/{stem}.ipynb"""
+    out_path = Path(output_dir)
+    name = out_path.name
+    if name.startswith('_') and name.endswith('_sage_'):
+        stem = name[1:-len('_sage_')]
+        p = out_path.parent / f"{stem}.ipynb"
+        return p if p.exists() else None
+    return None
+
+
+def _wf_read_notebook_cells(notebook_path):
+    """Return %%ask/%ask cells in order: [{id, prompt, outputs_html}]."""
+    if not notebook_path or not notebook_path.exists():
+        return []
+    try:
+        nb = json.loads(notebook_path.read_text(encoding='utf-8'))
+    except Exception:
+        return []
+    cells = []
+    for cell in nb.get('cells', []):
+        if cell.get('cell_type') != 'code':
+            continue
+        src_lines = cell.get('source', [])
+        if isinstance(src_lines, str):
+            src_lines = [src_lines]
+        source = ''.join(src_lines).strip()
+        if not source:
+            continue
+        first_line = source.split('\n', 1)[0].strip()
+        if first_line.startswith('%%ask'):
+            prompt = '\n'.join(source.split('\n')[1:]).strip()
+        elif first_line.startswith('%ask'):
+            prompt = first_line[len('%ask'):].strip()
+        else:
+            continue
+        html_chunks = []
+        for out in cell.get('outputs', []):
+            if out.get('output_type', '') in ('display_data', 'execute_result'):
+                h = out.get('data', {}).get('text/html', '')
+                if isinstance(h, list):
+                    h = ''.join(h)
+                if h:
+                    html_chunks.append(h)
+        cells.append({
+            'id': cell.get('id', ''),
+            'prompt': prompt,
+            'outputs_html': '\n'.join(html_chunks),
+        })
+    return cells
+
+
+def _wf_parse_outputs(outputs_html):
+    """Extract skill names and execute commands from cell output HTML."""
+    skills = []
+    seen = set()
+    for m in _WF_SKILL_RE.finditer(outputs_html):
+        name = m.group(2)
+        if name not in seen:
+            seen.add(name)
+            skills.append(name)
+    commands = [m.group(1) for m in _WF_EXEC_RE.finditer(outputs_html)]
+    return skills, commands
+
+
+def _wf_detect_runners(commands):
+    """Reduce execute commands to runner labels (fdp run python, python, etc.)."""
+    runners, seen = [], set()
+    for cmd in commands:
+        cmd = cmd.strip()
+        if _re_mod.match(r'^fdp\s+(run\s+)?python\b', cmd):
+            label = 'fdp run python'
+        elif _re_mod.search(r'python[0-9.]*\s+(-c|-m|[^\s]*\.py)', cmd):
+            label = 'python'
+        else:
+            continue
+        if label not in seen:
+            seen.add(label)
+            runners.append(label)
+    return runners
+
+
+# Full execute command from the <pre> inside <details> (not truncated).
+# Uses DOTALL to allow .* to span newlines across the full command.
+_WF_EXEC_FULL_RE = _re_mod.compile(
+    r'<b>execute</b>.*?<pre[^>]*>(.*?)</pre>',
+    _re_mod.IGNORECASE | _re_mod.DOTALL,
+)
+
+
+def _wf_extract_inline_code(outputs_html):
+    """Extract Python source from all 'python -c "..."' execute commands.
+
+    Pulls the FULL command from the <pre> tag inside <details>, then unescapes
+    shell and HTML escapes so the result is parseable Python source.
+    """
+    code_blocks = []
+    for m in _WF_EXEC_FULL_RE.finditer(outputs_html):
+        full_cmd = m.group(1)
+        # Unescape HTML entities (content was escaped by _format_tool_details)
+        full_cmd = full_cmd.replace('&amp;', '&').replace('&lt;', '<').replace('&gt;', '>')
+        # Match: ... python[3] -c "code"
+        pym = _re_mod.match(r'.*?python[0-9.]*\s+-c\s+"(.*)"\s*$', full_cmd, _re_mod.DOTALL)
+        if not pym:
+            continue
+        code = pym.group(1)
+        # Shell escapes inside double quotes: \" \\ \$ \` → the unescaped char.
+        # Single-pass regex sub prevents re-processing of replaced chars.
+        code = _re_mod.sub(r'\\([\\"$`])', r'\1', code)
+        code_blocks.append(code)
+    return code_blocks
+
+
+# Regex for other tool calls in cell output HTML
+_WF_WRITE_RE = _re_mod.compile(
+    r'<b>write_file</b>[^<]*?Writing:\s*<code>([^<]+)</code>', _re_mod.IGNORECASE)
+_WF_HTTP_RE = _re_mod.compile(
+    r'<b>(?:http_request|fetch_url)</b>[^<]*?(?:Fetching|GET|POST):\s*<code>([^<]+)</code>',
+    _re_mod.IGNORECASE)
+_WF_READ_RE = _re_mod.compile(
+    r'<b>read_file</b>[^<]*?Reading:\s*<code>([^<]+)</code>', _re_mod.IGNORECASE)
+
+
+def _wf_tool_call_substeps(outputs_html):
+    """Extract sub-step descriptions from tool calls when no .py files exist.
+
+    Returns a list of short descriptions derived from write_file, http_request,
+    read_file, and execute tool calls in the cell output HTML.
+    """
+    steps = []
+    seen = set()
+
+    def _add(desc):
+        k = desc.lower()
+        if k not in seen:
+            seen.add(k)
+            steps.append(desc)
+
+    # HTTP / fetch calls
+    for m in _WF_HTTP_RE.finditer(outputs_html):
+        url = m.group(1).strip()
+        # Extract domain
+        dm = _re_mod.match(r'https?://([^/]+)', url)
+        domain = dm.group(1) if dm else url[:40]
+        _add(f"Fetch data from {domain}")
+
+    # Execute calls (non-inline — e.g., shell commands)
+    for m in _WF_EXEC_RE.finditer(outputs_html):
+        cmd = m.group(1).strip()
+        if 'python' in cmd and '-c' in cmd:
+            continue  # handled separately via inline code extraction
+        if len(cmd) > 50:
+            cmd = cmd[:47] + '…'
+        _add(f"Run: {cmd}")
+
+    # Write calls (non-.py files — .py writes are scripts, not workflow outputs)
+    for m in _WF_WRITE_RE.finditer(outputs_html):
+        fpath = m.group(1).strip()
+        fname = Path(fpath).name
+        if fname.endswith('.py'):
+            continue
+        _add(f"Write {fname}")
+
+    # Read calls (skip skill reads and internal files)
+    for m in _WF_READ_RE.finditer(outputs_html):
+        fpath = m.group(1).strip()
+        if '/skills/' in fpath or '.sage_' in fpath:
+            continue
+        fname = Path(fpath).name
+        _add(f"Read {fname}")
+
+    return steps[:6]
+
+
+def _wf_extract_docstring(script_text):
+    try:
+        tree = _ast.parse(script_text)
+        return _ast.get_docstring(tree)
+    except Exception:
+        return None
+
+
+def _wf_extract_imports(script_text):
+    """Return non-stdlib, non-utility module names imported."""
+    try:
+        tree = _ast.parse(script_text)
+    except SyntaxError:
+        return []
+    modules = set()
+    for node in _ast.walk(tree):
+        if isinstance(node, _ast.Import):
+            for alias in node.names:
+                modules.add(alias.name.split('.')[0])
+        elif isinstance(node, _ast.ImportFrom) and node.module:
+            modules.add(node.module.split('.')[0])
+    return sorted(m for m in modules if m and m not in _COMMON_UTIL_MODULES)
+
+
+def _wf_extract_comments(script_text, max_indent=8, max_count=6):
+    """Top-level comments from script → sub-step descriptions."""
+    comments = []
+    try:
+        tokens = _tokenize.tokenize(_BytesIO(script_text.encode('utf-8')).readline)
+        for tok in tokens:
+            if tok.type != _tokenize.COMMENT:
+                continue
+            if tok.start[1] > max_indent:
+                continue
+            text = tok.string.lstrip('#').strip()
+            if len(text) < 6:
+                continue
+            low = text.lower()
+            if any(s in low for s in ('noqa', 'type:', 'pylint', 'todo', 'fixme', 'coding:', '!/usr')):
+                continue
+            # Skip URL documentation / path comments — not workflow steps
+            if 'http://' in text or 'https://' in text:
+                continue
+            if low.startswith(('pattern:', 'to:', 'from:', 'e.g.', 'example:', 'note:')):
+                continue
+            if len(text) > 70:
+                text = text[:67] + '…'
+            comments.append(text)
+    except (_tokenize.TokenizeError, IndentationError):
+        pass
+    seen = set()
+    unique = []
+    for c in comments:
+        k = c.lower()
+        if k not in seen:
+            seen.add(k)
+            unique.append(c)
+    return unique[:max_count]
+
+
+def _wf_analyze_scripts(file_paths, inline_code_blocks=None):
+    """Aggregate sub-step info from .py files and inline code blocks for a cell."""
+    scripts = [Path(p) for p in file_paths if str(p).endswith('.py')]
+    docstring = None
+    sub_steps = []
+    imports = set()
+
+    # Analyze saved .py scripts
+    for script in scripts:
+        try:
+            text = script.read_text(encoding='utf-8', errors='replace')
+        except Exception:
+            continue
+        if docstring is None:
+            ds = _wf_extract_docstring(text)
+            if ds:
+                docstring = ds.split('\n')[0].strip()
+        sub_steps.extend(_wf_extract_comments(text))
+        imports.update(_wf_extract_imports(text))
+
+    # Analyze inline python -c "..." code blocks (no .py file saved)
+    for code in (inline_code_blocks or []):
+        sub_steps.extend(_wf_extract_comments(code))
+        imports.update(_wf_extract_imports(code))
+
+    seen = set()
+    unique = []
+    for s in sub_steps:
+        k = s.lower()
+        if k not in seen:
+            seen.add(k)
+            unique.append(s)
+    return {'docstring': docstring, 'sub_steps': unique[:6], 'imports': sorted(imports)}
+
+
+def _wf_wrap_text(text, width=36, max_lines=3):
+    """Word-wrap text for node labels."""
+    if not text:
+        return ''
+    words = text.replace('\n', ' ').split()
+    lines, cur, cur_len = [], [], 0
+    for w in words:
+        added = len(w) + (1 if cur else 0)
+        if cur_len + added > width and cur:
+            lines.append(' '.join(cur))
+            if len(lines) == max_lines:
+                lines[-1] = lines[-1][:width - 1] + '…'
+                return '\n'.join(lines)
+            cur, cur_len = [w], len(w)
+        else:
+            cur.append(w)
+            cur_len += added
+    if cur and len(lines) < max_lines:
+        lines.append(' '.join(cur))
+    return '\n'.join(lines)
+
+
+_WF_HTML_TEMPLATE = """\
